# ClickUp API Token (Personal or Service Account)
CLICKUP_API_TOKEN=pk_your_token_here

# Custom Field ID for the "Generate PDF" dropdown
# Find this in ClickUp: task JSON → custom_fields → look for "Generate PDF" → "id"
GENERATE_PDF_FIELD_ID=

# Option orderindex for "Generated ✓" in the Generate PDF dropdown
# This is the orderindex of the "Generated" option (typically 2 if Generate=0, Regenerate=1, Generated=2)
GENERATED_OPTION_INDEX=2
